Sub DrawStar
  c$=Mid$(".....+**",Int(Rnd*8)+1,1)
  Select Case Int(Rnd*5)+1
    Case 1,2,3
      cc=RGB(white)
    Case 4
      cc=RGB(gray)
    Case 5
      cc=RGB(lightgray)
  End Select
  If TopDone=1 Then y=Int(Rnd*8)+303 Else y=Rnd*320
  Text Rnd*320,y,c$,,1,1,cc
End Sub

Sub StarField
For t=1 To 100
  DrawStar
Next
If topdone=0 Then
  Do
    i$=Inkey$
    t=t+1
    Pause 10
  Loop Until i$<>"" Or t=150
End If
topdone=1
  Text 0,303,""
  For t=1 To 20 Step .5
    Print
    For d=1 To Int(Rnd*4)
      DrawStar
    Next
    Pause ((25-t)*5)
  Next
End Sub

Sub PlayMusic
  If playqueue$="" And GameOver=0  And Detructed=0 Then PlayQueue$=m$(Int(Rnd*o)+1)
  Do
    Pause PauseIncrement
    CurrentPause=CurrentPause+PauseIncrement
    If CurrentPause>=NoteLength Then
      If CurrentNote$<>"" And CurrentLength<NoteLength Then
        If freqx<>0 Then Play Tone FreqX,FreqY,200
        CurrentLength=CurrentLength+PauseLength
      Else
        CurrentNote$=""
        CurrentLength=0
        If PlayQueue$<>"" Then
          currentnote$=Left$(PlayQueue$,Instr(PlayQueue$," "))
          playqueue$=Mid$(PlayQueue$,Len(currentNote$)+1,Len(PlayQueue$))
          Select Case CurrentNote$
            Case "0 "
              FreqX=0
              FreqY=0
            Case "X ","- "
            Case Else
              freqx=Val(currentnote$)
              If Instr(CurrentNote$,"|")<>0 Then
                freqy=Val(Mid$(Currentnote$,Instr(CurrentNote$,"|")+1,Len(CurrentNote$)))
              Else
                FreqY=FreqX
          End Select
          If FreqX<>0 Or CurrentNote$="X " Then
            Play tone freqx,freqy,200
          Else
            If CurrentNote$="- " Then Play tone 0,0,NoteLength*3
          End If
        End If
      End If
    End If
  Loop Until   CurrentPause>=PauseLength
  CurrentPause=0
  End If
End Sub

Sub SelfDestruct
  If DestructOn=0 Then
    opx=-5
    lh=px+1
    rh=px
    DestructOn=42
  Else
    If DestructOn/2=Int(DestructOn/2) Then
      dcolr=RGB(red)
      dback=RGB(yellow)
    Else
      dcolr=RGB(yellow)
      dback=RGB(red)
    End If
    Text 0,32,dmesg$,,1,2,dcolr,dback
    Text (lh*8)-16,287,"c",,9,2
    Text (rh*8)+8,287,"c",,9,2
  End If
  lh=lh-1
  rh=rh+1
  DestructOn=DestructOn-1
  Text (lh*8)-16,287,Chr$(36),,9,2,ShipColr(Int(Rnd*5))
  Text (rh*8)+8,287,Chr$(37),,9,2,ShipColr(Int(Rnd*5))
  Text (px*8)+(Rnd*20),298+(Rnd*16)-8,Chr$(65),,8,1,ShipColr(Int(Rnd*3)+2)
  MoveGuys
  MoveUFO
  If DestructOn=0 Then
    Destructed=1
    Text (px-1)*8,284,"   ",,1,3
    Text 0,32,String$(32,20),,1,2,0,0
    For t=1 To 20:i$=Inkey$:Next
    i$=""
    DeadShip=2
    px=-60
    Ships=Ships-1
  End If
End Sub

Sub MoveGuys
    cycle=cycle+1
    If cycle=3 Then cycle=1
    For t=1 To 5
      If Not (DestructON>0 And (t+y)*20<48) Then Text (x-1)*8,(t+y)*20,"c"+a$(cycle,t)+"c",,8,2,fc(t)
    Next t
End Sub

Sub MoveUFO
  If UFOon<>0 Then
    UFOx=UFOX-1
    Text UFOx*8,0,"45c",,8,2,UFOc
    If UFOx<-3 Then UFOon=0
  End If
End Sub

Sub NewLevel
  CLS
  setup
  mesg$="Next wave!"
  Select Case Int(Rnd*4)+1
    Case 1
      For d=0 To 152 Step 8
        Text 80,d-16,"          ",,1,2
        Text 80,d,mesg$,,1,2,RGB(white)
        PlayMusic
      Next d
      For d=1 To 10:PlayMusic:Next
      For d=72 To 320 Step 8
        Text d,152," "+mesg$,,1,2,RGB(white)
      PlayMusic
      Next d
    Case 2
      For d=-80 To 72 Step 8
        Text d,152," "+mesg$,,1,2,RGB(white)
        PlayMusic
      Next d
      For d=1 To 10
        PlayMusic
      Next
      For d=72 To 320 Step 8
        Text d,152," "+mesg$,,1,2,RGB(white)
        PlayMusic
      Next d
    Case 3
      tt=0
      For dd=1 To 2
        For d=1 To 19
          Text 80,tt-24,String$(10,32),,1,2
          Text 80,311-tt,String$(10,32),,1,2
          Text 80,tt,"N",,1,2,RGB(white)
          Text 96,287-tt,"e",,1,2,RGB(white)
          Text 112,tt,"x",,1,2,RGB(white)
          Text 128,287-tt,"t",,1,2,RGB(white)
          Text 160,tt,"W",,1,2,RGB(white)
          Text 176,287-tt,"a",,1,2,RGB(white)
          Text 192,tt,"v",,1,2,RGB(white)
          Text 208,287-tt,"e",,1,2,RGB(white)
          Text 224,tt,"!",,1,2,RGB(white)
          tt=tt+8
          playmusic
        Next
        If dd=1 Then
         For rp=1 To 11:PlayMusic:Next
        End If
      Next
    Case 4
      tt=0
      For d=1 To 11
        Text tt-16,152," Next",,1,2,RGB(white)
        Text 225-tt,152," Wave! ",,1,2,RGB(white)
        playmusic
        tt=tt+8
      Next
      tt=0
      For d=1 To 10:playmusic:Next
      For d=1 To 20
        tt=tt+8
        Text 70,144+tt,"      ",,1,2
        Text 160,160-tt,"      ",,1,2
        Text 80,154+tt,"Next",,1,2,RGB(white)
        Text 160,152-tt," Wave!",,1,2,RGB(white)
        playMusic
      Next
  End Select
  For d=1 To 10:i$=Inkey$:Next d
End Sub

Sub setup
  opx=-166
  taken$=""
  For t=1 To 5
    a$(1,t)=""
    a$(2,t)=""
    Do
      type=Int(Rnd*10)+1
    Loop Until Instr(taken$,  Chr$(30+(type*2)))=0
    taken$=taken$+Chr$(30+(type*2))
    For k=1 To 7
      a$(1,t)=a$(1,t)+Chr$(30+(type*2))+Chr$(99)
      a$(2,t)=a$(2,t)+Chr$(31+(type*2))+Chr$(99)
    Next k
  Next t
  x=1
  y=1
  cycle=0
  dir=1
  Move=MoveMax-1
  UFOon=0
End Sub


