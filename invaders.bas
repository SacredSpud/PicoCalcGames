  Do
    CLS
    Do
    If DestructOn<>0 Then
      SelfDestruct
      If Destructed=1 Then Destructed=0
    Else
      If playershots<>oplayershots Or px<>opx Then
        Text (opx)*8),287,"c",,9,2
        If PlayerShots<5 Then Text (px)*8,287,Chr$(ship),,9,2,ShipColr(playerShots)
        opx=px
      End If
    End If
    oplayershots=playershots
    If UFOon>1 Then Text 8*Ufox,0,uscore$+";",,8,2,UFOc
    If UFOx<35 Then Text 319-(8*(ships+1)),0,"c"+String$(ships,64),,8,1,RGB(white)
    If px>15 Then
      If ScoreSide=1 Then
        Text 319-(8*(7+Len(Str$(score)))),307,String$(7+Len(Str$(score)),32),,1,1,RGB(white)
      End If
      ScoreSide=-1
      Text 0,307,"Score: "+Str$(score)+" ",,1,1,RGB(white)
    Else
      If ScoreSide=-1 Then
        Text 0,307,String$(7+Len(Str$(score)),32),,1,1
      End If
      ScoreSide=1
      Text 319-(8*(7+Len(Str$(score)))),307,"Score: "+Str$(score),,1,1,RGB(white)
    End If
    move=move+1
    If move=MoveMax Then
      If UFOon=3 Then Text 8*UFOx,0,"    ":UFOon=0
      If UFOon=2 Then UFOon=3
      move=0
      x=x+dir
      If x>12 Or x<-1 Then
        dir=-dir
        Text 0,(y+1)*20,String$(20,32),,1,2
        y=y+1
        x=x+(dir)
        If y=9 Then PlayQueue$=Dead2$:AliensWin=1
      End If
      If UFOon=0 And Rnd>.9 Then
        UFOx=41
        UFOon=1
        Select Case Int(Rnd*5)+1
          Case 1
            UFOc=RGB(pink)
            UFOs=1000
            uscore$=":"
          Case 2
            UFOc=RGB(green)
            UFOs=2000
            uscore$="<"
          Case 3
            UFOc=RGB(yellow)
            UFOs=3000
            uscore$="="
          Case 4
            UFOc=RGB(cyan)
            UFOs=4000
            uscore$=">"
          Case 5
            UFOc=RGB(orange)
            UFOs=5000
            uscore$="?"
        End Select
      End If
      MoveGuys
      If AliensWin=0 And HoldShot=0 And DeadShip=0 And Rnd>ShotThreshold Then 'Shot
        Chosen=0
        For t=1 To 8
          If shotDir(t)=0 And Chosen=0 Then
            Do
              ShotX(t)=x+Int(Rnd*28)
              If ShotX(t)>0 Then
                For d=1 To 5
                  If Mid$(a$(1,d),ShotX(t),1)<>"c" Then Chosen=1
                Next
              End If
            Loop Until Chosen=1
            ShotY(t)=y+5
            ShotDir(t)=1
          End If
        Next
      End If
      'MoveGuys
    End If
    If move/2=Int(move/2) Then
      If UFOon=1 Then
        UFOx=UFOx-1
        If UFOx=-4 Then UFOon=0
        Text UFOx*8,0,"45c",,8,2,UFOc
      End If

      noshots=1
      playershots=0
      For t=1 To 8
        shot=0
        If ShotDir(t)=0 Then
          shoty(t)=-10:shotx(t)=-10
        Else
          noshots=0
          If shotdir(t)=1 Then
            If move/4=Int(move/4) Then
              shot=56
              shotcolr=RGB(cyan)
            Else
              shot=57
              shotcolr=RGB(white)
            End If
          Else
            PlayerShots=PlayerShots+1
            If move/4=Int(move/4) Then
              shot=54
              shotcolr=RGB(orange)
            Else
              shot=55
              shotcolr=RGB(yellow)
            End If
          End If
          shotY(t)=ShotY(t)+(ShotDir(t))
          Text (ShotX(t)*8)+7,OldShotY(t)*20,"c",,8,2
          Text (ShotX(t)*8)+7,ShotY(t)*20,Chr$(shot),,8,2,shotcolr
          OldShoty(t)=ShotY(t)
          If ShotDir(t)=1 And (ShotX(t)>px-3 And ShotX(t)<px+3) And ShotY(t)>14 And DestructOn=0 And DeadShip=0 Then 'Player Shot
            PlayQueue$=dead$
            DeadShip=1
            Select Case ShotX(t)
              Case px-2
                ship=33
              Case px+2
                ship=35
              Case Else
                ship=34
            End Select
          End If
          If UFOon=1 And ShotY(t)=0 And (ShotX(t)>UFOx-2 And ShotX(t)<UFOx+2) Then
            Score=Score+UFOs
            Text 8*Ufox,0,"    ",,1,2
            UFOon=2
          End If
          If Shoty(t)<0 Or ShotY(t)>15 Then ShotDir(t)=0
          HitX=0
          HitY=0
          If ShotY(t)>y And ShotY(t)<y+6 Then hitx=Int(2+((shotx(t)-x))/2)
            If hitx/2=Int(hitx/2) Then HitX=HitX-1
            If HitX>0 And HitX<15 Then
              If Mid$(a$(1,Shoty(t)-y),HitX,1)<>"c" Then
                hity=ShotY(t)-y
          Text (ShotX(t)*8)+7,ShotY(t)*20,Chr$(65),,8,2,shotcolr
              End If
            End If
          End If
          If HitY<>0 Then
            Score=Score+(((6-HitY)+(20-Y))*10)
            shotdir(t)=0
            For d=1 To 2
              b$=""
              If HitX>1 Then
                b$=Left$(a$(d,HitY),HitX-1)
              End If
              If Len(b$)+1<14 Then a$(d,hity)=b$+"c"+Mid$(a$(d,HitY),HitX+1,Len(a$(d,HitY))) Else If Len(b$)+1=14 Then a$(d,HitY)=b$+"c"
            Next d
emptycount=0
                For tt=1 To 5
                  If a$(1,tt)=String$(14,99) Then emptycount=emptycount+1
                Next tt
                If EmptyCount=5 Then NewLevel
            If shotdir(t)<>0 Then Text (ShotX(t)*8)+7,ShotY(t)*20,Chr$(shot),,8,2,shotcolr
            OldShotY(t)=ShotY(t)
          End If
          Hity=0
        Next t
      End If
      Playmusic
      If AliensWin=1 And NoShots=1 Then GameOver=1
      If DestructOn=0 And shipmoving=0 And DeadShip=0 Then
        i$=Inkey$
      Else
        If DeadShip>0 Then i$=Chr$(131)
      End If
      Select Case i$
        Case Chr$(130)
          px=px-1
          If shipmoving=0 Then
            shipmoving=2
          Else
            shipmoving=shipmoving-1
          End If
        Case Chr$(131)
          px=px+1
          If DeadShip=0 Then
            If shipmoving=0 Then
              shipmoving=2
            Else
              shipmoving=shipmoving-1
            End If
          End If
        Case Chr$(27)
          quit=1
        Case "H"
          If holdshot=1 Then holdshot=0 Else holdshot=1
        Case "1","2","3","4","5","6","7","8","9","0"
          shotthreshold=Val(i$)/10
        Case "C"
        Case " "
          If Playershots=4 Then
            PlayQueue$=ohalarm$
            dmesg$=">WEAPONS OVERHEATED<"
            SelfDestruct
            PlayerShots=0
            For t=1 To 8
              If ShotDir(t)=-1 Then
                Text (ShotX(t)*8)+7,ShotY(t)*20,"c",,8,2
                ShotX(t)=0
                ShotY(t)=0
                ShotDir(t)=0
              End If
            Next
          Else
            Chosen=0
            For t=1 To 8
              If ShotDir(t)=0 And Chosen=0 Then
                ShotX(t)=px
                ShotY(t)=14
                ShotDir(t)=-1
                Chosen=1
              End If
            Next t
          End If
      End Select
    End If
    If shipmoving=0 Then i$=""
    If px<0 Then px=0
    If px>36 And DeadShip=0 Then px=36
    If px=38 And DeadShip=1 Then DeadShip=2:Ship=32:px=-60:ships=ships-1
    If DeadShip=2 And PX=18 Then DeadShip=0:For t=1 To 50:q$=Inkey$:Next
    If Ships=0 Then GameOver=1
    Loop Until quit=1 Or GameOver=1
  Loop Until Quit=1 Or GameOver=1
  For t=1 To 8
    Text (ShotX(t)*8)+7,OldShotY(t)*20,"c",,8,2
  Next
  Text 265,0,"0 ships",,1,1,RGB(red)
  Text 290,287,"ccc",,9,2
  If Quit=1 Then
    PlayQueue$=ohalarm$
    Do
      dmesg$=">>>>SELF-DESTRUCT<<<<"
      SelfDestruct
      PlayMusic
    Loop Until Destructed=1
    Destructed=0
  End If
  quit=0
  If Len(PlayQueue$)+Len(dead2$)<255 Then
    PlayQueue$=PlayQueue$+Dead2$
  Else
    PlayQueue$=Dead2$
  End If
  AliensWin=0
  xx=x-4
  If xx>0 Then xy=-1 Else xy=1
    For pp=x To 6 Step xy
      For xx=1 To MoveMax/4
        If Quit=0 Then PlayMusic
        MoveUFO
      Next
      x=pp
      If Quit=0 Then MoveGuys
    Next
    For pp=y To 9
      For xx=1 To MoveMax/4
        If Quit=0 Then PlayMusic
        MoveUFO
      Next
      y=pp
      Text 0,(y)*20,String$(20,32),,1,2
      MoveGuys
    Next
    Text (opx)*8),287,"c",,9,2
     For pp=1 To 9
      If pp/2=Int(pp/2) Then d=1 Else d=2
      Text -332+(pp*16),303,e$(1,d),,8,2
      Text 319-(pp*16),303,e$(2,d),,8,2
      MoveGuys
      For tt=1 To MoveMax/4
        MoveUFO
        If Quit=0 Then PlayMusic
      Next
    Next
  scoreline$="Score: "+Str$(score)
  Text 0,48,">>>>>GAME  OVER<<<<<",,1,2,RGB(white)
  Text 48,100,"Press any key to play again,",,1,1,RGB(white)
Text 104,120,"or Esc to quit",,1,1,RGB(white)
  For t=1 To 20:i$=Inkey$:Next
  Do
      Text 160-(Len(scoreline$)*8),0,scoreline$,,1,2,RGB(yellow)
      d=d+1
      If d>2 Then d=1
      Text -332+(pp*16),303,e$(1,d),,8,2
      Text 319-(pp*16),303,e$(2,d),,8,2
      MoveGuys
      For tt=1 To MoveMax/4
        MoveUFO
        PlayMusic
      Next

    i$=Inkey$
  Loop Until i$<>""
  If i$=Chr$(27) Then quit=1
  gameover=0
  DeadShip=0
Loop Until quit=1
CLS
TOPDONE=0
StarField
Text 60,154,"Keep watching the skies!",,1,1,RGB(rust)
End
